+/**
+ * Formates a text as a list of bullets with automatic capitalization.
+ * Rule 1: Starts with a bullet if not empty.
+ * Rule 2: Capitalizes the first letter of each sentence.
+ */
+export const formatNotes = (text: string): string => {
+  if (!text) return text;
+
+  // Split into lines
+  const lines = text.split("\n");
+
+  const processedLines = lines.map((line) => {
+    if (!line) return line;
+
+    // Normalizar: quitar vi├▒eta existente si la hay para re-aplicar capitalizaci├│n
+    // Pero mantener los espacios que el usuario est├í escribiendo al final
+    let content = line.replace(/^[ΓÇó\-\*]\s*/, "");
+
+    // Capitalizar la primera letra de cada oraci├│n
+    // Buscamos: inicio de l├¡nea OR (punto/exclamaci├│n/pregunta seguido de uno o m├ís espacios)
+    // Seguido de una letra min├║scula
+    let formatted = content.replace(/(^|[.!?]\s+)([a-z├▒├í├⌐├¡├│├║])/g, (match) => match.toUpperCase());
+
+    // Asegurar que siempre empiece con vi├▒eta si tiene contenido
+    return `ΓÇó ${formatted}`;
+  });
+
+  return processedLines.join("\n");
+};
